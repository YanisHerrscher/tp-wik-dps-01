FROM python:3.11.15-trixie as build-stage

RUN pip install flask
RUN pip install -U pyinstaller

WORKDIR /app

COPY ./python/Lib/func.py ./Lib/
COPY ./main.py .

ENTRYPOINT [ "python" ]
RUN pyinstaller ./main.py 

FROM ubuntu

WORKDIR /app

RUN useradd wanderer
USER wanderer

COPY --chown=wanderer:wanderer --from=build-stage /app .
ENTRYPOINT [ "./dist/main/main" ]

CMD [  "80", "API" ]